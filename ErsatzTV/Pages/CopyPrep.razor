@page "/copy-prep"
@using System.Globalization
@using System.Threading
@using ErsatzTV.Application.CopyPrep
@using ErsatzTV.Application.CopyPrep.Commands
@using ErsatzTV.Application.CopyPrep.Queries
@using ErsatzTV.Core.Domain.CopyPrep
@implements IDisposable
@inject IMediator Mediator
@inject IStringLocalizer<ErsatzTV.Locals.Pages.CopyPrep> Loc

<MudForm Style="max-height: 100%">
    <div class="d-flex flex-column" style="height: 100vh; overflow-x: auto">
        <MudContainer MaxWidth="MaxWidth.False" Class="pt-8 px-6">
            <MudText Typo="Typo.h5" Class="mb-2">@Loc["LabelCopyPrep"]</MudText>
            <MudDivider Class="mb-6" />

            <MudGrid Class="mb-2">
                <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
                    <MudCard Class="mb-4">
                        <MudCardContent>
                            <MudText Typo="Typo.caption">@Loc["LabelQueued"]</MudText>
                            <MudText Typo="Typo.h4">@_summary.Queued</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
                    <MudCard Class="mb-4">
                        <MudCardContent>
                            <MudText Typo="Typo.caption">@Loc["LabelRunning"]</MudText>
                            <MudText Typo="Typo.h4">@_summary.Running</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
                    <MudCard Class="mb-4">
                        <MudCardContent>
                            <MudText Typo="Typo.caption">@Loc["LabelFailed"]</MudText>
                            <MudText Typo="Typo.h4">@_summary.Failed</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
                    <MudCard Class="mb-4">
                        <MudCardContent>
                            <MudText Typo="Typo.caption">@Loc["LabelCompletedToday"]</MudText>
                            <MudText Typo="Typo.h4">@_summary.CompletedToday</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
                    <MudCard Class="mb-4">
                        <MudCardContent>
                            <MudText Typo="Typo.caption">@Loc["LabelAvgDuration"]</MudText>
                            <MudText Typo="Typo.h4">@CopyPrepPageState.FormatDuration(_summary.AverageDuration)</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>

            <MudPaper Class="pa-4 mb-6">
                <MudGrid>
                    <MudItem xs="12" md="5">
                        <MudTextField T="string"
                                      Value="@_search"
                                      ValueChanged="OnSearchChanged"
                                      Label="@Loc["LabelSearch"]"
                                      Placeholder="@Loc["PlaceholderNameOrSourcePath"]"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Immediate="true"
                                      Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="string" Label="@Loc["LabelStatus"]" Value="@_statusFilter" ValueChanged="OnStatusChanged" Clearable="true">
                            @foreach (var status in _statuses)
                            {
                                <MudSelectItem T="string" Value="@status.ToString()">@Loc[$"Status{status.ToString()}"]</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="string" Label="@Loc["LabelLibrary"]" Value="@_libraryFilter" ValueChanged="OnLibraryChanged" Clearable="true">
                            @foreach (string library in _libraries)
                            {
                                <MudSelectItem T="string" Value="@library">@library</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="1" Class="d-flex justify-end">
                        <MudTooltip Text="@Loc["TooltipRefresh"]">
                            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                           Color="Color.Primary"
                                           Disabled="@_isBusy"
                                           OnClick="@RefreshAsync" />
                        </MudTooltip>
                    </MudItem>
                </MudGrid>
                <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2 d-block">
                    @Loc["LabelAutoRefresh"]
                </MudText>
            </MudPaper>

            <MudGrid>
                <MudItem xs="12" lg="8">
                    <MudPaper Class="pa-2">
                        <MudTable T="CopyPrepQueueItemViewModel"
                                  Hover="true"
                                  Dense="true"
                                  FixedHeader="true"
                                  Height="700px"
                                  Items="@_filteredItems"
                                  SelectedItem="@_selectedItem"
                                  SelectedItemChanged="OnSelectedItemChanged"
                                  RowClassFunc="SelectedRowClassFunc">
                            <HeaderContent>
                                <MudTh>@Loc["LabelMedia"]</MudTh>
                                <MudTh>@Loc["LabelStatus"]</MudTh>
                                <MudTh>@Loc["LabelProgress"]</MudTh>
                                <MudTh>@Loc["LabelUpdated"]</MudTh>
                                <MudTh>@Loc["LabelAction"]</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                @{ 
                                    CopyPrepDisplayStatus displayStatus = CopyPrepPageState.GetDisplayStatus(context, _nowUtc);
                                    bool isPossiblyStalled = CopyPrepPageState.IsPossiblyStalled(context, _nowUtc);
                                }
                                <MudTd DataLabel="@Loc["LabelMedia"]">
                                    <MudText Typo="Typo.body1">@context.DisplayName</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        @context.LibraryName · @Loc["LabelId"] @context.MediaItemId
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="Status">
                                    <div style="min-width: 150px;">
                                        <MudChip T="string"
                                                 Color="@GetStatusColor(displayStatus)"
                                                 Variant="Variant.Outlined"
                                                 Size="Size.Small">
                                            @FormatDisplayStatus(displayStatus)
                                        </MudChip>
                                        @if (isPossiblyStalled)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Warning" Class="d-block mt-1">
                                                @Loc["LabelPossiblyStalled"] · @CopyPrepPageState.FormatLastProgressAge(context, _nowUtc)
                                            </MudText>
                                        }
                                    </div>
                                </MudTd>
                                <MudTd DataLabel="Progress">
                                    <div style="min-width: 320px; display: grid; gap: 4px;">
                                        <div class="d-flex justify-space-between align-center">
                                            <MudText Typo="Typo.body2">
                                                @CopyPrepPageState.FormatProcessedDuration(context)
                                            </MudText>
                                            <MudText Typo="Typo.caption">
                                                @CopyPrepPageState.FormatProgressPercent(context, _nowUtc)
                                            </MudText>
                                        </div>
                                        <MudProgressLinear Rounded="true"
                                                           Color="@GetStatusColor(displayStatus)"
                                                           Value="@CopyPrepPageState.GetProgressBarValue(context, _nowUtc)" />
                                        <div style="display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:4px 12px;">
                                            <MudText Typo="Typo.caption">@Loc["LabelETA"]: @CopyPrepPageState.FormatEta(context)</MudText>
                                            <MudText Typo="Typo.caption">@Loc["LabelSpeed"]: @CopyPrepPageState.FormatSpeed(context)</MudText>
                                            <MudText Typo="Typo.caption">@Loc["LabelFrames"]: @CopyPrepPageState.FormatFrames(context)</MudText>
                                            <MudText Typo="Typo.caption">@Loc["LabelOutput"]: @CopyPrepPageState.FormatOutputSize(context)</MudText>
                                        </div>
                                    </div>
                                </MudTd>
                                <MudTd DataLabel="Updated">@FormatDateTime(context.UpdatedAt)</MudTd>
                                <MudTd DataLabel="Action">
                                    <div style="align-items: center; display: flex;">
                                        @if (CopyPrepPageState.CanRetry(context.Status))
                                        {
                                            <MudTooltip Text="@Loc["TooltipRetry"]">
                                                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                                               Color="Color.Primary"
                                                               Disabled="@_isBusy"
                                                               OnClick="@(() => RetryAsync(context))" />
                                            </MudTooltip>
                                        }
                                        else
                                        {
                                            <div style="width: 48px"></div>
                                        }

                                        @if (CopyPrepPageState.CanCancel(context.Status))
                                        {
                                            <MudTooltip Text="@Loc["TooltipCancel"]">
                                                <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                                               Color="Color.Warning"
                                                               Disabled="@_isBusy"
                                                               OnClick="@(() => CancelAsync(context))" />
                                            </MudTooltip>
                                        }
                                        else
                                        {
                                            <div style="width: 48px"></div>
                                        }
                                    </div>
                                </MudTd>
                            </RowTemplate>
                            <NoRecordsContent>
                                <MudText>@Loc["LabelNoMatchingItems"]</MudText>
                            </NoRecordsContent>
                            <LoadingContent>
                                <MudText>@Loc["LabelLoading"]</MudText>
                            </LoadingContent>
                        </MudTable>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" lg="4">
                    <MudPaper Class="pa-4" Style="height: 700px; overflow-y: auto;">
                        @if (_selectedItem is null)
                        {
                            <MudText Typo="Typo.h6" Class="mb-2">@Loc["LabelDetails"]</MudText>
                            <MudText>@Loc["LabelSelectItem"]</MudText>
                        }
                        else
                        {
                            CopyPrepDisplayStatus displayStatus = CopyPrepPageState.GetDisplayStatus(_selectedItem, _nowUtc);

                            <MudText Typo="Typo.h6">@_selectedItem.DisplayName</MudText>
                            <MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">@_selectedItem.LibraryName</MudText>

                            <MudText Typo="Typo.subtitle1" Class="mb-2">@Loc["LabelCurrentActivity"]</MudText>
                            <MudDivider Class="mb-3" />
                            <MudSimpleTable Dense="true" Class="mb-6">
                                <tbody>
                                <tr><td>@Loc["LabelStatus"]</td><td>@FormatDisplayStatus(displayStatus)</td></tr>
                                <tr><td>@Loc["LabelProgress"]</td><td>@CopyPrepPageState.FormatProgressPercent(_selectedItem, _nowUtc)</td></tr>
                                <tr><td>@Loc["LabelProcessed"]</td><td>@CopyPrepPageState.FormatProcessedDuration(_selectedItem)</td></tr>
                                <tr><td>@Loc["LabelLastProgress"]</td><td>@CopyPrepPageState.FormatLastProgressAge(_selectedItem, _nowUtc)</td></tr>
                                <tr><td>@Loc["LabelUpdated"]</td><td>@FormatDateTime(_selectedItem.UpdatedAt)</td></tr>
                                </tbody>
                            </MudSimpleTable>

                            <MudText Typo="Typo.subtitle1" Class="mb-2">@Loc["LabelRealtimeMetrics"]</MudText>
                            <MudDivider Class="mb-3" />
                            <MudSimpleTable Dense="true" Class="mb-6">
                                <tbody>
                                <tr><td>@Loc["LabelETA"]</td><td>@CopyPrepPageState.FormatEta(_selectedItem)</td></tr>
                                <tr><td>@Loc["LabelSpeed"]</td><td>@CopyPrepPageState.FormatSpeed(_selectedItem)</td></tr>
                                <tr><td>@Loc["LabelFrames"]</td><td>@CopyPrepPageState.FormatFrames(_selectedItem)</td></tr>
                                <tr><td>@Loc["LabelOutput"]</td><td>@CopyPrepPageState.FormatOutputSize(_selectedItem)</td></tr>
                                <tr><td>@Loc["LabelReason"]</td><td>@NullToDash(_selectedItem.Reason)</td></tr>
                                <tr><td>@Loc["LabelLastError"]</td><td>@NullToDash(_selectedItem.LastError)</td></tr>
                                </tbody>
                            </MudSimpleTable>

                            <MudText Typo="Typo.subtitle1" Class="mb-2">@Loc["LabelRecentEvents"]</MudText>
                            <MudDivider Class="mb-3" />
                            @if (_selectedItem.LogEntries.Count == 0)
                            {
                                <MudText>@Loc["LabelNoLogEntries"]</MudText>
                            }
                            else
                            {
                                @foreach (CopyPrepQueueLogEntryViewModel logEntry in _selectedItem.LogEntries
                                    .OrderByDescending(entry => entry.CreatedAt)
                                    .Take(10))
                                {
                                    <MudPaper Outlined="true" Class="pa-3 mb-3">
                                        <MudText Typo="Typo.caption">@FormatDateTime(logEntry.CreatedAt) · @logEntry.Level · @logEntry.Event</MudText>
                                        <MudText Typo="Typo.body2">@logEntry.Message</MudText>
                                        @if (!string.IsNullOrWhiteSpace(logEntry.Details))
                                        {
                                            <MudText Typo="Typo.caption">@logEntry.Details</MudText>
                                        }
                                    </MudPaper>
                                }
                            }
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudContainer>
    </div>
</MudForm>

@code {
    private static readonly CopyPrepStatus[] _statuses = Enum.GetValues<CopyPrepStatus>();
    private readonly DateTimeFormatInfo _dateTimeFormat = CultureInfo.CurrentCulture.DateTimeFormat;
    private readonly PeriodicTimer _autoRefreshTimer = new(TimeSpan.FromSeconds(5));
    private readonly CancellationTokenSource _refreshLoopCancellation = new();
    private Task _refreshLoop = Task.CompletedTask;

    private List<CopyPrepQueueItemViewModel> _allItems = [];
    private List<CopyPrepQueueItemViewModel> _filteredItems = [];
    private List<string> _libraries = [];
    private CopyPrepSummaryViewModel _summary = new(0, 0, 0, 0, null);
    private CopyPrepQueueItemViewModel _selectedItem;
    private string _search = string.Empty;
    private string _statusFilter;
    private string _libraryFilter;
    private bool _isBusy;
    private DateTime _nowUtc = DateTime.UtcNow;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        _refreshLoop = RunRefreshLoopAsync(_refreshLoopCancellation.Token);
    }

    public void Dispose()
    {
        _refreshLoopCancellation.Cancel();
        _autoRefreshTimer.Dispose();
        _refreshLoopCancellation.Dispose();
    }

    private async Task RunRefreshLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (await _autoRefreshTimer.WaitForNextTickAsync(cancellationToken))
            {
                if (_isBusy)
                {
                    continue;
                }

                try
                {
                    await InvokeAsync(async () =>
                    {
                        await RefreshAsync();
                        StateHasChanged();
                    });
                }
                catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
                {
                    break;
                }
                catch
                {
                    // ignore transient refresh failures and try again on the next tick
                }
            }
        }
        catch (OperationCanceledException)
        {
            // page disposed
        }
    }

    private async Task RefreshAsync()
    {
        int? selectedId = _selectedItem?.Id;
        _isBusy = true;

        try
        {
            _allItems = await Mediator.Send(new GetCopyPrepQueueItems(500));
            _nowUtc = DateTime.UtcNow;
            _libraries = _allItems
                .Select(item => item.LibraryName)
                .Where(name => !string.IsNullOrWhiteSpace(name))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(name => name, StringComparer.CurrentCultureIgnoreCase)
                .ToList();

            ApplyFiltersAndSelection(selectedId);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void ApplyFiltersAndSelection(int? selectedId = null)
    {
        CopyPrepStatus? status = Enum.TryParse<CopyPrepStatus>(_statusFilter, out CopyPrepStatus parsedStatus)
            ? parsedStatus
            : null;

        _filteredItems = CopyPrepPageState.ApplyFilters(_allItems, _search, status, _libraryFilter).ToList();
        _summary = CopyPrepPageState.BuildSummary(_allItems, _nowUtc);

        int? desiredId = selectedId ?? _selectedItem?.Id;
        _selectedItem = CopyPrepPageState.ResolveSelectedItem(_filteredItems, desiredId);
    }

    private Task OnSelectedItemChanged(CopyPrepQueueItemViewModel item)
    {
        _selectedItem = item;
        return Task.CompletedTask;
    }

    private Task OnSearchChanged(string search)
    {
        _search = search ?? string.Empty;
        ApplyFiltersAndSelection();
        return Task.CompletedTask;
    }

    private Task OnStatusChanged(string status)
    {
        _statusFilter = status;
        ApplyFiltersAndSelection();
        return Task.CompletedTask;
    }

    private Task OnLibraryChanged(string library)
    {
        _libraryFilter = library;
        ApplyFiltersAndSelection();
        return Task.CompletedTask;
    }

    private async Task RetryAsync(CopyPrepQueueItemViewModel item)
    {
        if (!CopyPrepPageState.CanRetry(item.Status))
        {
            return;
        }

        _isBusy = true;
        try
        {
            await Mediator.Send(new RetryCopyPrepQueueItem(item.Id));
        }
        finally
        {
            _isBusy = false;
        }

        await RefreshAsync();
    }

    private async Task CancelAsync(CopyPrepQueueItemViewModel item)
    {
        if (!CopyPrepPageState.CanCancel(item.Status))
        {
            return;
        }

        _isBusy = true;
        try
        {
            await Mediator.Send(new CancelCopyPrepQueueItem(item.Id));
        }
        finally
        {
            _isBusy = false;
        }

        await RefreshAsync();
    }

    private string SelectedRowClassFunc(CopyPrepQueueItemViewModel item, int index) =>
        item.Id == _selectedItem?.Id ? "mud-table-row-selected" : string.Empty;

    private string FormatDateTime(DateTime value) => value.ToLocalTime().ToString("g", _dateTimeFormat);

    private string FormatNullableDateTime(DateTime? value) => value.HasValue ? FormatDateTime(value.Value) : "—";

    private static string NullToDash(string value) => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private string FormatDisplayStatus(CopyPrepDisplayStatus status) => Loc[$"Status{status.ToString()}"];

    private static Color GetStatusColor(CopyPrepDisplayStatus status) => status switch
    {
        CopyPrepDisplayStatus.Queued => Color.Info,
        CopyPrepDisplayStatus.Starting => Color.Info,
        CopyPrepDisplayStatus.Running => Color.Primary,
        CopyPrepDisplayStatus.Done => Color.Success,
        CopyPrepDisplayStatus.Failed => Color.Error,
        _ => Color.Default
    };
}
