@page "/copy-prep"
@using System.Globalization
@using ErsatzTV.Application.CopyPrep
@using ErsatzTV.Application.CopyPrep.Commands
@using ErsatzTV.Application.CopyPrep.Queries
@using ErsatzTV.Core.Domain.CopyPrep
@inject IMediator Mediator

<MudForm Style="max-height: 100%">
    <div class="d-flex flex-column" style="height: 100vh; overflow-x: auto">
        <MudContainer MaxWidth="MaxWidth.False" Class="pt-8 px-6">
            <MudText Typo="Typo.h5" Class="mb-2">Copy Prep</MudText>
            <MudDivider Class="mb-6"/>

            <MudGrid Class="mb-2">
                <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
                    <MudCard Class="mb-4">
                        <MudCardContent>
                            <MudText Typo="Typo.caption">Queued</MudText>
                            <MudText Typo="Typo.h4">@_summary.Queued</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
                    <MudCard Class="mb-4">
                        <MudCardContent>
                            <MudText Typo="Typo.caption">Running</MudText>
                            <MudText Typo="Typo.h4">@_summary.Running</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
                    <MudCard Class="mb-4">
                        <MudCardContent>
                            <MudText Typo="Typo.caption">Failed</MudText>
                            <MudText Typo="Typo.h4">@_summary.Failed</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
                    <MudCard Class="mb-4">
                        <MudCardContent>
                            <MudText Typo="Typo.caption">Completed Today</MudText>
                            <MudText Typo="Typo.h4">@_summary.CompletedToday</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
                    <MudCard Class="mb-4">
                        <MudCardContent>
                            <MudText Typo="Typo.caption">Avg Duration</MudText>
                            <MudText Typo="Typo.h4">@CopyPrepPageState.FormatDuration(_summary.AverageDuration)</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>

            <MudPaper Class="pa-4 mb-6">
                <MudGrid>
                    <MudItem xs="12" md="5">
                        <MudTextField T="string"
                                      Value="@_search"
                                      ValueChanged="OnSearchChanged"
                                      Label="Search"
                                      Placeholder="Name or source path"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Immediate="true"
                                      Clearable="true"/>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="string" Label="Status" Value="@_statusFilter" ValueChanged="OnStatusChanged" Clearable="true">
                            @foreach (var status in _statuses)
                            {
                                <MudSelectItem T="string" Value="@status.ToString()">@status</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="string" Label="Library" Value="@_libraryFilter" ValueChanged="OnLibraryChanged" Clearable="true">
                            @foreach (string library in _libraries)
                            {
                                <MudSelectItem T="string" Value="@library">@library</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="1" Class="d-flex justify-end">
                        <MudTooltip Text="Refresh">
                            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                           Color="Color.Primary"
                                           Disabled="@_isBusy"
                                           OnClick="@RefreshAsync"/>
                        </MudTooltip>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudGrid>
                <MudItem xs="12" lg="8">
                    <MudPaper Class="pa-2">
                        <MudTable T="CopyPrepQueueItemViewModel"
                                  Hover="true"
                                  Dense="true"
                                  FixedHeader="true"
                                  Height="700px"
                                  Items="@_filteredItems"
                                  SelectedItem="@_selectedItem"
                                  SelectedItemChanged="OnSelectedItemChanged"
                                  RowClassFunc="SelectedRowClassFunc">
                            <HeaderContent>
                                <MudTh>Media</MudTh>
                                <MudTh>Source / Library</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Progress</MudTh>
                                <MudTh>Updated</MudTh>
                                <MudTh>Duration</MudTh>
                                <MudTh>Action</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Media">
                                    <MudText Typo="Typo.body1">@context.DisplayName</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">ID @context.MediaItemId</MudText>
                                </MudTd>
                                <MudTd DataLabel="Source / Library">
                                    <MudText Typo="Typo.body2">@context.LibraryName</MudText>
                                    <MudTooltip Text="@context.SourcePath">
                                        <MudText Typo="Typo.caption">@context.SourcePath</MudText>
                                    </MudTooltip>
                                </MudTd>
                                <MudTd DataLabel="Status">
                                    <MudChip T="string" Color="@GetStatusColor(context.Status)" Variant="Variant.Outlined" Size="Size.Small">
                                        @context.Status
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="Progress">
                                    <div style="min-width: 140px;">
                                        <MudProgressLinear Rounded="true"
                                                           Color="@GetStatusColor(context.Status)"
                                                           Value="@CopyPrepPageState.GetPseudoProgressPercent(context.Status)"/>
                                        <MudText Typo="Typo.caption">@CopyPrepPageState.GetPseudoProgressPercent(context.Status)%</MudText>
                                    </div>
                                </MudTd>
                                <MudTd DataLabel="Updated">@FormatDateTime(context.UpdatedAt)</MudTd>
                                <MudTd DataLabel="Duration">@CopyPrepPageState.FormatDuration(context)</MudTd>
                                <MudTd DataLabel="Action">
                                    <div style="align-items: center; display: flex;">
                                        @if (CopyPrepPageState.CanRetry(context.Status))
                                        {
                                            <MudTooltip Text="Retry">
                                                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                                               Color="Color.Primary"
                                                               Disabled="@_isBusy"
                                                               OnClick="@(() => RetryAsync(context))"/>
                                            </MudTooltip>
                                        }
                                        else
                                        {
                                            <div style="width: 48px"></div>
                                        }

                                        @if (CopyPrepPageState.CanCancel(context.Status))
                                        {
                                            <MudTooltip Text="Cancel">
                                                <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                                               Color="Color.Warning"
                                                               Disabled="@_isBusy"
                                                               OnClick="@(() => CancelAsync(context))"/>
                                            </MudTooltip>
                                        }
                                        else
                                        {
                                            <div style="width: 48px"></div>
                                        }
                                    </div>
                                </MudTd>
                            </RowTemplate>
                            <NoRecordsContent>
                                <MudText>No matching queue items</MudText>
                            </NoRecordsContent>
                            <LoadingContent>
                                <MudText>Loading...</MudText>
                            </LoadingContent>
                        </MudTable>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" lg="4">
                    <MudPaper Class="pa-4" Style="height: 700px; overflow-y: auto;">
                        @if (_selectedItem is null)
                        {
                            <MudText Typo="Typo.h6" Class="mb-2">Details</MudText>
                            <MudText>Select a queue item to inspect job details and recent logs.</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.h6">@_selectedItem.DisplayName</MudText>
                            <MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">@_selectedItem.LibraryName</MudText>

                            <MudText Typo="Typo.subtitle1" Class="mb-2">Summary</MudText>
                            <MudDivider Class="mb-3" />
                            <MudSimpleTable Dense="true" Class="mb-6">
                                <tbody>
                                <tr><td>Status</td><td>@_selectedItem.Status</td></tr>
                                <tr><td>Reason</td><td>@NullToDash(_selectedItem.Reason)</td></tr>
                                <tr><td>Attempts</td><td>@_selectedItem.AttemptCount</td></tr>
                                <tr><td>Duration</td><td>@CopyPrepPageState.FormatDuration(_selectedItem)</td></tr>
                                <tr><td>Updated</td><td>@FormatDateTime(_selectedItem.UpdatedAt)</td></tr>
                                </tbody>
                            </MudSimpleTable>

                            <MudText Typo="Typo.subtitle1" Class="mb-2">Job Info</MudText>
                            <MudDivider Class="mb-3" />
                            <MudSimpleTable Dense="true" Class="mb-6">
                                <tbody>
                                <tr><td>Queued</td><td>@FormatDateTime(_selectedItem.QueuedAt)</td></tr>
                                <tr><td>Started</td><td>@FormatNullableDateTime(_selectedItem.StartedAt)</td></tr>
                                <tr><td>Completed</td><td>@FormatNullableDateTime(_selectedItem.CompletedAt)</td></tr>
                                <tr><td>Replaced</td><td>@FormatNullableDateTime(_selectedItem.ReplacedAt)</td></tr>
                                <tr><td>Canceled</td><td>@FormatNullableDateTime(_selectedItem.CanceledAt)</td></tr>
                                <tr><td>Exit Code</td><td>@(_selectedItem.LastExitCode?.ToString() ?? "—")</td></tr>
                                <tr><td>Source</td><td>@NullToDash(_selectedItem.SourcePath)</td></tr>
                                <tr><td>Target</td><td>@NullToDash(_selectedItem.TargetPath)</td></tr>
                                <tr><td>Archive</td><td>@NullToDash(_selectedItem.ArchivePath)</td></tr>
                                <tr><td>Last Log Path</td><td>@NullToDash(_selectedItem.LastLogPath)</td></tr>
                                <tr><td>Last Error</td><td>@NullToDash(_selectedItem.LastError)</td></tr>
                                <tr><td>Last Command</td><td>@NullToDash(_selectedItem.LastCommand)</td></tr>
                                </tbody>
                            </MudSimpleTable>

                            <MudText Typo="Typo.subtitle1" Class="mb-2">Logs Tail</MudText>
                            <MudDivider Class="mb-3" />
                            @if (_selectedItem.LogEntries.Count == 0)
                            {
                                <MudText>No log entries</MudText>
                            }
                            else
                            {
                                @foreach (CopyPrepQueueLogEntryViewModel logEntry in _selectedItem.LogEntries
                                    .OrderByDescending(entry => entry.CreatedAt)
                                    .Take(10))
                                {
                                    <MudPaper Outlined="true" Class="pa-3 mb-3">
                                        <MudText Typo="Typo.caption">@FormatDateTime(logEntry.CreatedAt) · @logEntry.Level · @logEntry.Event</MudText>
                                        <MudText Typo="Typo.body2">@logEntry.Message</MudText>
                                        @if (!string.IsNullOrWhiteSpace(logEntry.Details))
                                        {
                                            <MudText Typo="Typo.caption">@logEntry.Details</MudText>
                                        }
                                    </MudPaper>
                                }
                            }
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudContainer>
    </div>
</MudForm>

@code {
    private static readonly CopyPrepStatus[] _statuses = Enum.GetValues<CopyPrepStatus>();
    private readonly DateTimeFormatInfo _dateTimeFormat = CultureInfo.CurrentCulture.DateTimeFormat;

    private List<CopyPrepQueueItemViewModel> _allItems = [];
    private List<CopyPrepQueueItemViewModel> _filteredItems = [];
    private List<string> _libraries = [];
    private CopyPrepSummaryViewModel _summary = new(0, 0, 0, 0, null);
    private CopyPrepQueueItemViewModel _selectedItem;
    private string _search = string.Empty;
    private string _statusFilter;
    private string _libraryFilter;
    private bool _isBusy;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        int? selectedId = _selectedItem?.Id;
        _isBusy = true;

        try
        {
            _allItems = await Mediator.Send(new GetCopyPrepQueueItems(500));
            _libraries = _allItems
                .Select(item => item.LibraryName)
                .Where(name => !string.IsNullOrWhiteSpace(name))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(name => name, StringComparer.CurrentCultureIgnoreCase)
                .ToList();

            ApplyFiltersAndSelection(selectedId);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void ApplyFiltersAndSelection(int? selectedId = null)
    {
        CopyPrepStatus? status = Enum.TryParse<CopyPrepStatus>(_statusFilter, out CopyPrepStatus parsedStatus)
            ? parsedStatus
            : null;

        _filteredItems = CopyPrepPageState.ApplyFilters(_allItems, _search, status, _libraryFilter).ToList();
        _summary = CopyPrepPageState.BuildSummary(_allItems, DateTime.UtcNow);

        int? desiredId = selectedId ?? _selectedItem?.Id;
        _selectedItem = desiredId.HasValue
            ? _allItems.FirstOrDefault(item => item.Id == desiredId.Value)
            : _filteredItems.FirstOrDefault();

        if (_selectedItem is not null && _filteredItems.All(item => item.Id != _selectedItem.Id))
        {
            _selectedItem = _allItems.FirstOrDefault(item => item.Id == _selectedItem.Id) ?? _filteredItems.FirstOrDefault();
        }
    }

    private Task OnSelectedItemChanged(CopyPrepQueueItemViewModel item)
    {
        _selectedItem = item;
        return Task.CompletedTask;
    }

    private Task OnSearchChanged(string search)
    {
        _search = search ?? string.Empty;
        ApplyFiltersAndSelection();
        return Task.CompletedTask;
    }

    private Task OnStatusChanged(string status)
    {
        _statusFilter = status;
        ApplyFiltersAndSelection();
        return Task.CompletedTask;
    }

    private Task OnLibraryChanged(string library)
    {
        _libraryFilter = library;
        ApplyFiltersAndSelection();
        return Task.CompletedTask;
    }

    private async Task RetryAsync(CopyPrepQueueItemViewModel item)
    {
        if (!CopyPrepPageState.CanRetry(item.Status))
        {
            return;
        }

        _isBusy = true;
        try
        {
            await Mediator.Send(new RetryCopyPrepQueueItem(item.Id));
        }
        finally
        {
            _isBusy = false;
        }

        await RefreshAsync();
    }

    private async Task CancelAsync(CopyPrepQueueItemViewModel item)
    {
        if (!CopyPrepPageState.CanCancel(item.Status))
        {
            return;
        }

        _isBusy = true;
        try
        {
            await Mediator.Send(new CancelCopyPrepQueueItem(item.Id));
        }
        finally
        {
            _isBusy = false;
        }

        await RefreshAsync();
    }

    private string SelectedRowClassFunc(CopyPrepQueueItemViewModel item, int index) =>
        item.Id == _selectedItem?.Id ? "mud-table-row-selected" : string.Empty;

    private string FormatDateTime(DateTime value) => value.ToLocalTime().ToString("g", _dateTimeFormat);

    private string FormatNullableDateTime(DateTime? value) => value.HasValue ? FormatDateTime(value.Value) : "—";

    private static string NullToDash(string value) => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static Color GetStatusColor(CopyPrepStatus status) => status switch
    {
        CopyPrepStatus.Queued => Color.Info,
        CopyPrepStatus.Processing => Color.Primary,
        CopyPrepStatus.Prepared => Color.Secondary,
        CopyPrepStatus.Replaced => Color.Success,
        CopyPrepStatus.Failed => Color.Error,
        CopyPrepStatus.Canceled => Color.Warning,
        CopyPrepStatus.Skipped => Color.Dark,
        _ => Color.Default
    };
}
